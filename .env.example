# ============================================================================
# CodeFlix Production Configuration
# ============================================================================

# ============================================================================
# DEPLOYMENT & ENVIRONMENT
# ============================================================================
NODE_ENV=production
DEPLOYMENT_DROPLET_IP=YOUR_DROPLET_IP

# ============================================================================
# FRONTEND CONFIGURATION (Vite)
# ============================================================================
# Development: http://localhost:4000/api
# Production: /api (relative path, uses same domain)
# Production with external API: https://api.example.com
VITE_API_URL=/api

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================
PORT=4000
LOG_LEVEL=info

# CORS: Comma-separated list of allowed origins
# Development: http://localhost:5173,http://localhost:3000
# Production: https://example.com,https://www.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# AI PROVIDER API KEYS
# ============================================================================
# Required: Add at least one provider API key

# OpenAI (https://platform.openai.com)
# Model: gpt-4o (default)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx

# Anthropic Claude (https://console.anthropic.com)
# Model: claude-sonnet-4-20250514 (default)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Google Gemini (https://ai.google.dev)
# Model: gemini-1.5-flash (default)
GEMINI_API_KEY=xxxxxxxxxxxxx

# Groq (https://console.groq.com)
# Model: llama-3.3-70b-versatile (default)
GROQ_API_KEY=gsk-xxxxxxxxxxxxx

# Ollama (Local or Cloud)
# Run: ollama serve
# Model: llama3.2 (default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ============================================================================
# OPTIONAL: MONITORING & DEBUGGING
# ============================================================================
# Enable debug logging for development
# DEBUG=codeflix:*

# Error tracking service (Sentry, DataDog, etc.)
# MONITORING_ENABLED=true
# SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ============================================================================
# SECURITY & RATE LIMITING
# ============================================================================
# Rate limit: 100 requests per 15 minutes per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

